<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Hippodrome.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2679"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="APP_CONFIG" custom_title="0" dock_id="1" table="4,10:mainAPP_CONFIG"/><dock_state state="000000ff00000000fd0000000100000002000001280000030efc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000001280000012800ffffff000001280000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- 1. Таблица конфигурации
CREATE TABLE IF NOT EXISTS APP_CONFIG (
    id integer NOT NULL CONSTRAINT APP_CONFIG_pk PRIMARY KEY,
    config_key varchar(50),
    config_value varchar(255),
    description text
);

-- 2. Таблица пользователей
CREATE TABLE IF NOT EXISTS APP_USERS (
    id integer NOT NULL CONSTRAINT APP_USERS_pk PRIMARY KEY,
    password_hash varchar(255),
    full_name varchar(100),
    role varchar(20),
    created_at text,
    username varchar(50)
);

-- 3. Таблица владельцев
CREATE TABLE IF NOT EXISTS OWNERS (
    id integer NOT NULL CONSTRAINT OWNERS_pk PRIMARY KEY,
    first_name varchar(50),
    last_name varchar(50),
    phone varchar(20),
    email varchar(100),
    address text,
    registration_date date
);

-- 4. Таблица лошадей
CREATE TABLE IF NOT EXISTS HORSES (
    id integer NOT NULL CONSTRAINT HORSES_pk PRIMARY KEY,
    name varchar(50),
    breed varchar(50),
    age integer,
    race_experience integer,
    purchase_price decimal(10,2),
    OWNERS_id integer NOT NULL,
    CONSTRAINT HORSES_OWNERS FOREIGN KEY (OWNERS_id)
    REFERENCES OWNERS (id)
);

-- 5. Таблица жокеев
CREATE TABLE IF NOT EXISTS JOCKEYS (
    id integer NOT NULL CONSTRAINT JOCKEYS_pk PRIMARY KEY,
    first_name varchar(50),
    last_name varchar(50),
    birth_year integer,
    experience_years integer,
    weight_kg real,
    license_number varchar(30)
);

-- 6. Таблица заездов
CREATE TABLE IF NOT EXISTS RACES (
    id integer NOT NULL CONSTRAINT RACES_pk PRIMARY KEY,
    race_date date,
    race_number integer,
    horse_id integer,
    jockey_id integer,
    finish_position integer,
    prize_amount decimal(10,2) NOT NULL,
    HORSES_id integer NOT NULL,
    JOCKEYS_id integer NOT NULL,
    CONSTRAINT RACES_HORSES FOREIGN KEY (HORSES_id)
    REFERENCES HORSES (id),
    CONSTRAINT RACES_JOCKEYS FOREIGN KEY (JOCKEYS_id)
    REFERENCES JOCKEYS (id)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
